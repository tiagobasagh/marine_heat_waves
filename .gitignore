# ==============================================================================
# 1. ARCHIVOS DE DATOS Y MULTIMEDIA
# ==============================================================================
*.csv
*.nc
*.nc4
*.mp4
*.xlsx
*.xls

# ==============================================================================
# 2. EXCEPCIONES PARA CONFIGURACIÓN DE CARPETAS (REGRESO DE .GITKEEP)
# ==============================================================================
# Permitir explícitamente que los archivos .gitkeep se suban, 
# incluso si están dentro de carpetas con archivos ignorados.
!**/.gitkeep

# ==============================================================================
# 3. JUPYTER NOTEBOOKS Y ENTORNOS VIRTUALES
# ==============================================================================
.ipynb_checkpoints/
*/.ipynb_checkpoints/
__pycache__/
*/__pycache__/
*.pyc

# Carpetas de entornos virtuales locales (si creas uno en la raíz)
.venv/
venv/
env/
.env

# ==============================================================================
# 4. CONFIGURACIONES DE PYTHON Y COMPILACIÓN (EMPAQUETADO TOML)
# ==============================================================================
build/
dist/
*.egg-info/
.eggs/

# ==============================================================================
# 5. ARCHIVOS DEL SISTEMA OPERATIVO
# ==============================================================================
.DS_Store
.DS_Store?
ehthumbs.db
Icon?
Thumbs.db